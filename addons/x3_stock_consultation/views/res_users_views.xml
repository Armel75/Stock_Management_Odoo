<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_res_users_form_x3_stock" model="ir.ui.view">
        <field name="name">res.users.form.x3.stock</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='preferences']" position="inside">
                <group string="SAGE X3 - Stocks &amp; Prix" groups="base.group_system">
                    <field name="x3_price_region"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
