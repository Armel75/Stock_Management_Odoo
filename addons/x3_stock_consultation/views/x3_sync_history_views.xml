<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ======================== LISTE ======================== -->
    <record id="view_x3_sync_history_tree" model="ir.ui.view">
        <field name="name">x3.sync.history.tree</field>
        <field name="model">x3.sync.history</field>
        <field name="arch" type="xml">
            <tree string="Historique des synchronisations" limit="30" default_order="sync_date desc">
                <field name="sync_date" string="Date"/>
                <field name="sync_type" string="Type"/>
                <field name="state" string="Statut" widget="badge"
                       decoration-success="state == 'success'"
                       decoration-warning="state == 'running'"
                       decoration-danger="state == 'error'"/>
                <field name="articles_count" string="Articles"/>
                <field name="duration_seconds" string="Durée (s)" widget="float_time"/>
            </tree>
        </field>
    </record>

    <!-- ======================== FORMULAIRE ======================== -->
    <record id="view_x3_sync_history_form" model="ir.ui.view">
        <field name="name">x3.sync.history.form</field>
        <field name="model">x3.sync.history</field>
        <field name="arch" type="xml">
            <form string="Détail synchronisation">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            Synchronisation du <field name="sync_date"/>
                        </h1>
                    </div>
                    <group>
                        <field name="sync_date"/>
                        <field name="sync_type"/>
                        <field name="state" widget="badge"/>
                        <field name="articles_count"/>
                        <field name="duration_seconds" widget="float_time"/>
                        <field name="version"/>
                    </group>
                    <field name="error_message" nolabel="1"
                           invisible="error_message == False"/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ======================== ACTION ======================== -->
    <record id="action_x3_sync_history" model="ir.actions.act_window">
        <field name="name">Historique synchronisations</field>
        <field name="res_model">x3.sync.history</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'sync_launch_action': 'action_x3_manual_sync'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucune synchronisation enregistrée.
            </p>
            <p>
                Chaque nuit à 00h00, une synchronisation automatique est lancée.
                Vous pouvez aussi lancer une synchronisation manuelle depuis la configuration.
            </p>
        </field>
    </record>
</odoo>
